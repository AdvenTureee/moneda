{
  "name": "moneda",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=high",
    "security:secrets": "git ls-files -z --cached --others --exclude-standard | xargs -0 secretlint",
    "test": "node --test --import jiti/register --import ./tests/test-setup.ts tests/*.test.ts",
    "start": "next start",
    "backfill:pii": "node --env-file=.env scripts/backfill-pii.mjs",
    "nullify:legacy-pii": "node --env-file=.env scripts/nullify-legacy-pii.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@react-three/drei": "10.7.7",
