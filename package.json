    "@supabase/supabase-js": "^2.106.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.40.0",
    "groq-sdk": "^1.2.0",
    "next": "16.2.9",
    "nextjs-toploader": "^3.9.17",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "three": "0.184.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.2",
